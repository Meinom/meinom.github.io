---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home - Meinom's Blog">
  <section class="hero">
    <h1>Welcome to Meinom's Blog</h1>
    <p>Exploring web development, technology, and digital innovation</p>
    <a href="/blog" class="cta-button">Read Blog Posts</a>
  </section>

  <section class="about">
    <h2>About This Site</h2>
    <p>
      This blog explores modern web development practices, including frameworks
      like Astro, performance optimization, and best practices for building
      fast, scalable web applications.
    </p>
  </section>

  <section class="featured">
    <h2>Featured Articles</h2>
    <div class="featured-grid">
      <article class="featured-card">
        <h3>Getting Started with Astro</h3>
        <p>Learn why Astro is perfect for content-focused websites with zero JavaScript by default.</p>
        <a href="/blog">Read more →</a>
      </article>
      <article class="featured-card">
        <h3>Web Performance Tips</h3>
        <p>Practical techniques to optimize your website's loading speed and user experience.</p>
        <a href="/blog">Read more →</a>
      </article>
      <article class="featured-card">
        <h3>Building with Components</h3>
        <p>A deep dive into component-based architecture for scalable projects.</p>
        <a href="/blog">Read more →</a>
      </article>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    border-radius: 0.5rem;
    margin-bottom: 4rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin: 0 0 1rem 0;
    color: var(--primary-color);
  }

  .hero p {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: white;
    border-radius: 0.25rem;
    font-weight: 500;
    transition: background-color 0.2s;
  }

  .cta-button:hover {
    background-color: var(--accent-color);
    text-decoration: none;
  }

  .about {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 2rem;
    background-color: var(--bg-secondary);
    border-radius: 0.5rem;
  }

  .about h2 {
    color: var(--primary-color);
    margin-top: 0;
  }

  .featured {
    margin-top: 4rem;
  }

  .featured h2 {
    color: var(--primary-color);
    text-align: center;
    margin-bottom: 2rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .featured-card {
    padding: 2rem;
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    transition: all 0.2s;
  }

  .featured-card:hover {
    border-color: var(--primary-color);
    box-shadow: 0 4px 12px rgba(15, 118, 110, 0.1);
  }

  .featured-card h3 {
    color: var(--primary-color);
    margin-top: 0;
  }

  .featured-card a {
    color: var(--accent-color);
    font-weight: 500;
  }
</style>
