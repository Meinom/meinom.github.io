---
interface Props {
  title?: string;
}

const { title = "Meinom's Blog" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      :root {
        --primary-color: #0f766e;
        --accent-color: #14b8a6;
        --bg-primary: #ffffff;
        --bg-secondary: #f8fafc;
        --text-color: #1e293b;
        --text-muted: #64748b;
        --border-color: #e2e8f0;
      }

      html {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-color);
      }

      body {
        margin: 0;
        padding: 0;
        line-height: 1.6;
      }

      a {
        color: var(--primary-color);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
    </style>
  </head>
  <body>
    <header>
      <nav style="border-bottom: 1px solid var(--border-color); padding: 1rem; margin-bottom: 2rem;">
        <div style="max-width: 1200px; margin: 0 auto;">
          <a href="/" style="font-weight: bold; font-size: 1.25rem;">Meinom</a>
          <div style="display: flex; gap: 2rem; margin-top: 1rem;">
            <a href="/">Home</a>
            <a href="/blog">Blog</a>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer style="border-top: 1px solid var(--border-color); padding: 2rem 1rem; text-align: center; color: var(--text-muted); margin-top: 4rem;">
      <p>&copy; {new Date().getFullYear()} Meinom. All rights reserved.</p>
    </footer>
  </body>
</html>
